# Wix backend — server-side env vars for the Vercel functions (api/lead.js, api/posts.js).
# Set these in the Vercel project (Settings > Environment Variables), then redeploy.
# Both are read server-side only; nothing here is exposed to the browser.

# Admin API key for the "Tropik Media" Wix project.
# Generate at https://manage.wix.com/account/api-keys with scopes: Manage Contacts + Read Blog.
WIX_API_KEY=

# Site ID of the "Tropik Media" Wix project (not secret).
WIX_SITE_ID=a895c48f-6677-4005-994f-aa58f23d2206
